# Stock Radar — Required Environment Variables
# Copy this file to .env and fill in your values.

# Alpha Vantage — market data, prices, fundamentals, technicals, news sentiment
# Get a free key at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# Finnhub — earnings call transcripts
# Get a free key at: https://finnhub.io/register
FINNHUB_API_KEY=

# Anthropic Claude API — top-tier escalation for complex multi-document analysis
# Get a key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI API — mid-tier escalation (optional, used before Anthropic in escalation chain)
# Get a key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Ollama — local LLM inference server (RTX 4090 desktop)
# Optional: defaults to http://localhost:11434 if not set
# OLLAMA_HOST=http://localhost:11434

# SEC EDGAR — free API, no key needed, just a contact email for User-Agent header
SEC_EDGAR_EMAIL=your-email@example.com
